# DocuMind environment — copy to .env and fill in.
# The installer (install.sh) generates the secret values for you and PRESERVES
# them on re-run. .env is gitignored; never commit it.

# ---- Public identity ----------------------------------------------------------
DOMAIN=docs.example.com                 # apex domain pointed at this server (A/AAAA record)
ACME_EMAIL=admin@example.com            # Let's Encrypt account email (= ADMIN_EMAIL)
ADMIN_EMAIL=admin@example.com           # bootstrap admin account, created on first run
PUBLIC_BASE_URL=https://docs.example.com
ACME_CA=https://acme-v02.api.letsencrypt.org/directory  # LE prod; installer swaps to staging when DOCUMIND_ACME_STAGING=1

# ---- Images -------------------------------------------------------------------
IMAGE_OWNER=alighaemi9731                # ghcr.io/<owner>/documind-{api,web}
IMAGE_TAG=latest

# ---- Database -----------------------------------------------------------------
POSTGRES_USER=documind
POSTGRES_PASSWORD=                      # GENERATED by installer (CSPRNG)
POSTGRES_DB=documind
DATABASE_URL=postgresql+asyncpg://documind:CHANGE_ME@postgres:5432/documind

# ---- Secrets (GENERATED by installer; never hand-edit once issued) ------------
JWT_SECRET=                             # >=256-bit CSPRNG; app refuses to start if weak
MASTER_KEY_FERNET=                      # Fernet key for BYOK encryption at rest

# ---- Default provider (works out-of-the-box) ----------------------------------
OPERATOR_DEFAULT_GEMINI_KEY=            # optional free Gemini key; seeds the shared default
DEFAULT_PROVIDER=google

# ---- Behavior toggles ---------------------------------------------------------
REGISTRATION_MODE=open                  # open | approval | invite
MAX_UPLOAD_MB=25                        # also enforced at Caddy (request_body) and the API
INGEST_CONCURRENCY=1                    # in-process ingest worker concurrency (RAM guard)
UPLOADS_DIR=/data/uploads               # where uploaded files are stored (the api uploads volume)
MAX_PENDING_INGEST_PER_USER=20          # per-user cap on simultaneously-pending ingest jobs (429 over limit)
ENABLE_LOCAL_EMBEDDINGS=false           # bge-m3 offline embeddings (needs >=4GB RAM)
GROUNDING_MIN_SCORE=0.55               # raw cosine floor for "answer exists in docs" (calibrated per language later)
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# ---- Ops ----------------------------------------------------------------------
LOG_LEVEL=info
ENVIRONMENT=production
